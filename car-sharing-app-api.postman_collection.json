                {
                  "key": "is_active",
                  "value": "true",
                  "description": "Filter by active status (optional)"
                }
              ]
            },
            "description": "Get rentals filtered by user ID and active status"
          },
          "response": []
        },
        {
          "name": "Get Rental by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
