              "raw": "{{baseUrl}}/rentals/{{rentalId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "rentals",
                "{{rentalId}}"
              ]
            },
            "description": "Get specific rental by ID"
          },
          "response": []
        },
        {
          "name": "Return Rental",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/rentals/{{rentalId}}/return",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "rentals",
                "{{rentalId}}",
                "return"
              ]
            },
            "description": "Return a rented car and set actual return date"
          },
          "response": []
        }
      ],
      "description": "Rental management endpoints"
