{
  "info": {
    "_postman_id": "car-sharing-api-collection",
    "name": "Car Sharing App API",
    "description": "Comprehensive API collection for car sharing application with authentication, car management, rentals, payments, and user management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "car-sharing-app"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"securePassword123\",\n  \"repeatPassword\": \"securePassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/registration",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "registration"
              ]
            },
            "description": "Register a new user in the system"
          },
          "response": []
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.environment.set('accessToken', response.token);",
                  "    console.log('Access token saved to environment');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"securePassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Authenticate user and get access token"
          },
          "response": []
        }
      ],
      "description": "Authentication endpoints for user registration and login"
    },
    {
      "name": "Cars",
      "item": [
        {
          "name": "Create Car (Manager Only)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"Toyota Camry\",\n  \"brand\": \"Toyota\",\n  \"type\": \"SEDAN\",\n  \"inventory\": 5,\n  \"dailyFee\": 45.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/cars",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cars"
              ]
            },
            "description": "Create a new car (Manager role required)"
          },
          "response": []
        },
        {
          "name": "Get All Cars",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/cars?page=0&size=10&sort=id,asc",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cars"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0",
                  "description": "Page number (0-based)"
                },
                {
                  "key": "size",
                  "value": "10",
                  "description": "Number of items per page"
                },
                {
                  "key": "sort",
                  "value": "id,asc",
                  "description": "Sort criteria (field,direction)"
                }
              ]
            },
            "description": "Get paginated list of all cars"
          },
          "response": []
        },
        {
          "name": "Get Car by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/cars/{{carId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cars",
                "{{carId}}"
              ]
            },
            "description": "Get detailed information about a specific car"
          },
          "response": []
        },
        {
          "name": "Update Car (Manager Only)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"Toyota Camry 2024\",\n  \"brand\": \"Toyota\",\n  \"type\": \"SEDAN\",\n  \"inventory\": 3,\n  \"dailyFee\": 50.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/cars/{{carId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cars",
                "{{carId}}"
              ]
            },
            "description": "Update car information (Manager role required)"
          },
          "response": []
        },
        {
          "name": "Delete Car (Manager Only)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/cars/{{carId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cars",
                "{{carId}}"
              ]
            },
            "description": "Delete a car by ID (Manager role required)"
          },
          "response": []
        }
      ],
      "description": "Car management endpoints"
    },
    {
      "name": "Rentals",
      "item": [
        {
          "name": "Create Rental",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"carId\": {{carId}},\n  \"rentalDate\": \"2025-08-05\",\n  \"returnDate\": \"2025-08-10\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/rentals",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "rentals"
